{
  "name": "danielbdyer-website",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "vite build && node ./scripts/filter-pages-json.mjs",
    "build:analyze": "ANALYZE=1 vite build && node ./scripts/filter-pages-json.mjs",
    "build:deploy": "pnpm typecheck && pnpm build && node ./scripts/verify-deploy-artifacts.mjs",
    "preview": "pnpm build && vite preview",
    "preview:deploy": "pnpm build:deploy && wrangler dev",
    "deploy:workers": "pnpm build:deploy && wrangler deploy",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run && pnpm test:smoke",
    "test:fast": "vitest",
    "test:smoke": "playwright test --grep @smoke",
    "test:e2e": "playwright test",
    "e2e:serve": "pnpm build && python3 -m http.server 4317 --bind 127.0.0.1 -d dist/client",
    "lighthouse": "pnpm build && lhci autorun --config=./lighthouserc.cjs",
    "setup": "node ./scripts/setup-playwright.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/literata": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tanstack/react-router": "^1.168.23",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.42",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "happy-dom": "^20.0.0",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.1",
    "wrangler": "^4.14.4"
  }
}
