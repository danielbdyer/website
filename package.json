{
  "name": "danielbdyer-website",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "vite build && node ./scripts/filter-pages-json.mjs",
    "build:analyze": "ANALYZE=1 vite build && node ./scripts/filter-pages-json.mjs",
    "build:deploy": "pnpm typecheck && pnpm build && node ./scripts/verify-deploy-artifacts.mjs",
    "preview": "pnpm build && vite preview",
    "preview:deploy": "pnpm build:deploy && wrangler dev",
    "deploy:workers": "pnpm build:deploy && wrangler deploy",
    "lint": "pnpm lint:eslint && pnpm lint:css && pnpm lint:contrast && pnpm lint:component-shapes && pnpm lint:md && pnpm lint:spell && pnpm lint:secrets && pnpm lint:wikilinks && pnpm lint:voice",
    "lint:component-shapes": "node ./scripts/check-component-shapes.mjs",
    "lint:wikilinks": "node ./scripts/check-spec-wikilinks.mjs",
    "lint:voice": "node ./scripts/check-voice-and-copy.mjs",
    "lint:knip": "knip --no-progress",
    "lint:eslint": "eslint src/",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:contrast": "node ./scripts/check-color-contrast.mjs",
    "lint:md": "markdownlint-cli2",
    "lint:spell": "cspell --no-progress \"**/*.{ts,tsx,md,mdx,css,yaml,json}\"",
    "lint:secrets": "secretlint \"**/*\" --secretlintignore .gitignore",
    "lint:knip": "knip --no-progress",
    "lint:html": "html-validate dist/client/**/*.html",
    "lint:audit": "audit-ci --config audit-ci.json",
    "test:coverage": "vitest run --coverage",
    "doctor": "pnpm typecheck && pnpm lint && pnpm test:fast --run",
    "format": "prettier --write src/",
    "test": "pnpm lint && pnpm build && vitest run && pnpm test:smoke",
    "test:fast": "vitest",
    "test:smoke": "playwright test --grep @smoke",
    "test:e2e": "playwright test",
    "test:perf": "xvfb-run -a playwright test --grep @perf --project=desktop-chromium",
    "e2e:serve": "python3 -m http.server 4317 --bind 127.0.0.1 -d dist/client",
    "e2e:build-and-serve": "pnpm build && pnpm e2e:serve",
    "e2e:install": "playwright install chromium",
    "lighthouse": "pnpm build && lhci autorun --config=./lighthouserc.cjs && pnpm lighthouse:report",
    "lighthouse:report": "node ./scripts/print-lighthouse-scores.mjs",
    "size": "pnpm build && size-limit",
    "setup": "node ./scripts/setup-playwright.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource-variable/literata": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@tanstack/react-router": "^1.168.23",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "marked": "^18.0.2",
    "motion": "^12.38.0",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@secretlint/secretlint-rule-preset-recommend": "^12.3.1",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-start": "^1.167.42",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "audit-ci": "^7.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cspell": "^10.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "happy-dom": "^20.0.0",
    "html-validate": "^10.13.1",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "secretlint": "^12.3.1",
    "size-limit": "^12.1.0",
    "stylelint": "^17.9.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.1",
    "wrangler": "^4.14.4"
  }
}
